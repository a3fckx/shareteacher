# ── ShareTeacher environment ──────────────────────────────────────────────
# Copy to .env.local and fill. There is NO mock mode: every adapter talks to
# its real service, so a live lesson needs live credentials plus a human (mic,
# a one-time ChatGPT login via the Kernel live view, and a public tunnel for
# RECALL_OUTPUT_URL so the meeting bot can actually join).

# ── Data (Postgres via docker compose; host port 5433) ─────────────────────
DATABASE_URL=postgres://shareteacher:shareteacher@localhost:5433/shareteacher

# ── Runway Character (face, voice, realtime convo, tool calling) ───────────
RUNWAY_API_KEY=
RUNWAY_BASE_URL=https://api.dev.runwayml.com
# ShareTeacher Guide avatar id (status READY). Same value, exposed to the client.
RUNWAY_CHARACTER_ID=c3d36541-d60e-4f26-80cf-2689eeece4bc
NEXT_PUBLIC_RUNWAY_CHARACTER_ID=c3d36541-d60e-4f26-80cf-2689eeece4bc
# Runway live-preset voice presetId (not a custom-voice UUID).
RUNWAY_VOICE_ID=clara

# ── Recall.ai (meeting bot that joins Meet/Zoom/Teams) ─────────────────────
RECALL_API_KEY=
RECALL_REGION=ap-northeast-1
# Public URL of THIS app's teaching screen the bot streams into the call.
# For local dev use an ngrok/cloudflared tunnel (localhost will not work).
RECALL_OUTPUT_URL=http://localhost:3000/stage

# ── Kernel (cloud browser runtime: profiles, live view, recordings) ────────
KERNEL_API_KEY=
KERNEL_BASE_URL=https://api.onkernel.com
# Named persistent profile reused every session so the ChatGPT login persists
# (requires a paid Kernel plan; first login is a human takeover via live view).
KERNEL_PROFILE_NAME=shareteacher

# ── Browser-use sidecar (FastAPI Python service over the Kernel CDP url) ────
BROWSER_AGENT_URL=http://localhost:8700
# OpenAI model the sidecar's browser-use agent uses for /click, /type, /task.
BROWSER_AGENT_MODEL=gpt-4.1-mini
# Optional extra domains (comma-separated) added to the built-in lesson allowlist
# that bounds where the shared browser may navigate. Leave blank for defaults.
BROWSER_ALLOWLIST=

# ── OpenAI (browser-use LLM; the ChatGPT lesson drives the real website) ───
OPENAI_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
